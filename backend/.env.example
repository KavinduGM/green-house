# ----- Greenhouse backend configuration -----
# Copy this file to ".env" and fill in real values on your VPS.

# HTTP API port (the React app talks to this)
PORT=8080

# MQTT broker port (your ESP32 connects here). 1883 = plain, default.
MQTT_PORT=1883

# Username/password the ESP32 must use to connect to MQTT.
MQTT_USERNAME=greenhouse
MQTT_PASSWORD=change-me-mqtt

# ---- App login (single user) ----
# Set your login email + a password. On first boot a user is created from these.
APP_EMAIL=kavindu@groovymark.com
APP_PASSWORD=change-me-please

# Secret used to sign login tokens. Use a long random string.
JWT_SECRET=replace-with-a-long-random-secret-string

# ---- Claude / Anthropic ----
# IMPORTANT: paste your NEW (rotated) Anthropic API key here. Never in the app.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-opus-4-8

# Where uploaded diagram photos are stored on disk
UPLOAD_DIR=./data/uploads

# SQLite database file
DB_PATH=./data/greenhouse.db
